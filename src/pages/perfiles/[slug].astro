---
import SiteHeader from "../../components/header/SiteHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { profilePages, profiles } from "../../data/profiles";

export function getStaticPaths() {
  return profilePages.map((page) => ({
    params: { slug: page.slug },
    props: { page }
  }));
}

const { page } = Astro.props;

const detailTitle = page.detail?.displayTitle ?? page.title;
const pageTitle = `${detailTitle} | Perfiles | GeneraRecetas`;
const pageDescription = page.detail?.overview ?? `Informacion del perfil ${detailTitle} dentro de GeneraRecetas.`;
const parentLabel = page.parentName ?? "Perfiles";
const parentProfile = page.isSubprofile ? profiles.find((profile) => profile.id === page.parentId) ?? null : null;
const siblingPages =
  parentProfile?.subprofiles.map((subprofile) => ({
    slug: subprofile.slug,
    title: subprofile.name,
    isActive: subprofile.slug === page.slug
  })) ?? [];
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={`/perfiles/${page.slug}`}>
  <SiteHeader />

  <main class="px-[14px] pb-0 pt-[24px] md:pt-[30px] min-[1200px]:px-[20px] min-[1200px]:pt-[38px]">
    <section class="relative w-full py-[26px] md:py-[36px] min-[1200px]:py-[48px]">
      <span class="pointer-events-none absolute left-1/2 bottom-0 h-px w-screen -translate-x-1/2 bg-gr-border/18" aria-hidden="true"></span>

      <div class="mx-auto w-full max-w-[1080px] px-[16px] md:px-[24px] min-[1200px]:px-[32px]">
        {
          siblingPages.length > 1 && (
            <nav
              class="border-b border-gr-border/14 pb-[18px] text-center md:pb-[22px] min-[1200px]:pb-[26px]"
              aria-label={`Secciones de ${parentLabel}`}
            >
              <p class="font-space text-[0.76rem] font-[700] uppercase tracking-[0.16em] text-gr-gold">
                Otras secciones de {parentLabel}
              </p>

              <ul class="mt-[14px] flex flex-wrap justify-center gap-[10px] md:gap-[12px]">
                {siblingPages.map((item) => (
                  <li>
                    {item.isActive ? (
                      <span class="inline-flex items-center rounded-[999px] border border-gr-border/18 bg-[rgb(47_86_104_/_0.05)] px-[14px] py-[8px] font-space text-[0.95rem] font-[500] text-gr-blue">
                        {item.title}
                      </span>
                    ) : (
                      <a
                        href={`/perfiles/${item.slug}`}
                        class="inline-flex items-center rounded-[999px] border border-gr-border/14 px-[14px] py-[8px] font-space text-[0.95rem] font-[500] text-gr-blue/84 transition-colors duration-200 hover:border-gr-gold/30 hover:text-gr-gold"
                      >
                        {item.title}
                      </a>
                    )}
                  </li>
                ))}
              </ul>
            </nav>
          )
        }

        <a
          href="/perfiles"
          class={`inline-flex items-center gap-[9px] border-b border-gr-blue/22 pb-[4px] font-space text-[1rem] font-[700] uppercase tracking-[0.08em] text-gr-blue transition-colors duration-200 hover:border-gr-gold hover:text-gr-gold ${siblingPages.length > 1 ? "mt-[18px] md:mt-[22px] min-[1200px]:mt-[26px]" : ""}`}
        >
          <svg viewBox="0 0 24 24" class="h-[16px] w-[16px] fill-none stroke-current stroke-[2.2]" aria-hidden="true">
            <path d="M15 6 9 12l6 6" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          ATRAS
        </a>

        <div class="mt-[18px] border-b border-gr-border/18 pb-[18px] md:pb-[22px] min-[1200px]:pb-[26px]">
          <p class="font-space text-[0.8rem] font-[600] uppercase tracking-[0.16em] text-gr-gold">
            {page.isSubprofile ? parentLabel : "Perfil"}
          </p>

          <h1 class="gr-heading-1 mt-[10px] max-w-[16ch] text-gr-blue min-[1200px]:max-w-[18ch]">
            {detailTitle}
          </h1>
        </div>

        {
          page.detail && (
            <div class="mt-[18px] md:mt-[22px] min-[1200px]:mt-[28px]">
              <section class="pb-[20px] md:pb-[24px] min-[1200px]:pb-[28px]">
                <p class="gr-body max-w-[74ch] text-gr-blue/92">{page.detail.overview}</p>
              </section>

              {
                page.detail.stats.length > 0 && (
                  <section class="border-t border-gr-border/14 py-[20px] md:py-[24px] min-[1200px]:py-[28px]">
                    <dl class="grid gap-x-[22px] gap-y-[14px] md:grid-cols-2 md:gap-y-[18px]">
                      {page.detail.stats.map((item) => (
                        <div class="border-b border-gr-border/12 pb-[12px] md:pb-[14px]">
                          <dt class="font-space text-[0.76rem] font-[700] uppercase tracking-[0.16em] text-gr-gold">
                            {item.label}
                          </dt>
                          <dd class="gr-body mt-[8px] text-gr-blue/90">{item.value}</dd>
                        </div>
                      ))}
                    </dl>
                  </section>
                )
              }

              <section class="border-t border-gr-border/14 py-[20px] md:py-[24px] min-[1200px]:py-[28px]">
                <p class="font-space text-[0.8rem] font-[700] uppercase tracking-[0.16em] text-gr-gold">
                  {page.detail.servicesTitle}
                </p>
                <p class="gr-body mt-[10px] max-w-[76ch] text-gr-blue/92">{page.detail.servicesIntro}</p>

                <ul class="mt-[18px] grid gap-x-[18px] gap-y-[2px] sm:grid-cols-2 lg:grid-cols-3 min-[1200px]:mt-[22px]">
                  {page.detail.services.map((service) => (
                    <li class="relative border-b border-gr-border/10 py-[11px] pl-[14px] font-space text-[1rem] font-[500] text-gr-blue before:absolute before:left-0 before:top-1/2 before:h-[12px] before:w-[2px] before:-translate-y-1/2 before:rounded-full before:bg-gr-gold">
                      {service}
                    </li>
                  ))}
                </ul>
              </section>
            </div>
          )
        }
      </div>
    </section>
  </main>
</BaseLayout>
