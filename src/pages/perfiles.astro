---
import { getImage } from "astro:assets";
import SiteHeader from "../components/header/SiteHeader.astro";
import ProfilesSection from "../components/profiles/ProfilesSection.vue";
import BaseLayout from "../layouts/BaseLayout.astro";
import perfilPropAnimales from "../assets/profiles/PerfilPropAnimales (1).webp";
import perfilProfesionales from "../assets/profiles/PerfilPropAnimales (7).webp";
import perfilComercializadora from "../assets/profiles/PerfilPropAnimales (3).webp";
import perfilEntidades from "../assets/profiles/PerfilPropAnimales (4).webp";
import perfilClinicaVet from "../assets/profiles/PerfilPropAnimales (2).webp";
import perfilFabrica from "../assets/profiles/PerfilPropAnimales (5).webp";
import perfilLaboratorio from "../assets/profiles/PerfilPropAnimales (6).webp";

const mobileImageSizes = "(min-width: 768px) 47vw, calc(100vw - 32px)";
const desktopImageSizes = "(min-width: 1440px) 24vw, (min-width: 1200px) 27vw, 100vw";
const profileMobileWidths = [320, 480, 640, 960];
const profileDesktopWidths = [480, 720, 960];

const profileImageSources = {
  "propietarios-animales": perfilPropAnimales,
  profesionales: perfilProfesionales,
  comercializadoras: perfilComercializadora,
  entidades: perfilEntidades,
  "clinica-veterinaria": perfilClinicaVet,
  fabrica: perfilFabrica,
  laboratorio: perfilLaboratorio
};

const optimizedProfileImages = Object.fromEntries(
  await Promise.all(
    Object.entries(profileImageSources).map(async ([profileId, source]) => {
      const [mobileAvif, mobileWebp, desktopAvif, desktopWebp] = await Promise.all([
        getImage({
          src: source,
          format: "avif",
          quality: 45,
          widths: profileMobileWidths
        }),
        getImage({
          src: source,
          format: "webp",
          quality: 58,
          widths: profileMobileWidths
        }),
        getImage({
          src: source,
          format: "avif",
          quality: 45,
          widths: profileDesktopWidths
        }),
        getImage({
          src: source,
          format: "webp",
          quality: 58,
          widths: profileDesktopWidths
        })
      ]);

      return [
        profileId,
        {
          mobileAvifSrc: mobileAvif.src,
          mobileAvifSrcSet: mobileAvif.srcSet.attribute || mobileAvif.src,
          mobileWebpSrc: mobileWebp.src,
          mobileWebpSrcSet: mobileWebp.srcSet.attribute || mobileWebp.src,
          mobileSizes: mobileImageSizes,
          desktopAvifSrc: desktopAvif.src,
          desktopAvifSrcSet: desktopAvif.srcSet.attribute || desktopAvif.src,
          desktopWebpSrc: desktopWebp.src,
          desktopWebpSrcSet: desktopWebp.srcSet.attribute || desktopWebp.src,
          desktopSizes: desktopImageSizes,
          fallbackSrc: mobileWebp.src,
          width: source.width,
          height: source.height
        }
      ];
    })
  )
);

const firstProfileImage = optimizedProfileImages["propietarios-animales"];
---

<BaseLayout
  title="Perfiles | GeneraRecetas"
  description="Perfiles de acceso de GeneraRecetas para propietarios, profesionales, comercializadoras, entidades y perfiles del sector veterinario y ganadero."
  canonical="/perfiles"
>
  <Fragment slot="head">
    <link
      rel="preload"
      as="image"
      href={firstProfileImage.mobileAvifSrc}
      imagesrcset={firstProfileImage.mobileAvifSrcSet}
      imagesizes={firstProfileImage.mobileSizes}
      media="(max-width: 1199px)"
      type="image/avif"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href={firstProfileImage.desktopAvifSrc}
      imagesrcset={firstProfileImage.desktopAvifSrcSet}
      imagesizes={firstProfileImage.desktopSizes}
      media="(min-width: 1200px)"
      type="image/avif"
      fetchpriority="high"
    />
  </Fragment>

  <style is:inline>
    .profiles-stage {
      opacity: 0;
      transform: translate3d(0, 20px, 0);
      animation: profiles-stage-enter 680ms cubic-bezier(0.22, 1, 0.36, 1) 160ms forwards;
      will-change: opacity, transform;
    }

    @keyframes profiles-stage-enter {
      from {
        opacity: 0;
        transform: translate3d(0, 20px, 0);
      }

      to {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .profiles-stage {
        opacity: 1;
        transform: none;
        animation: none;
      }
    }
  </style>

  <SiteHeader />

  <main class="px-[14px] pb-0 pt-[24px] md:pt-[30px] min-[1200px]:px-[20px] min-[1200px]:pt-[38px]">
    <div class="profiles-stage">
      <ProfilesSection profileImages={optimizedProfileImages} client:media="(max-width: 1199px)" />
    </div>
  </main>
</BaseLayout>
