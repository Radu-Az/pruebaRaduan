---
import SiteHeader from "../components/header/SiteHeader.astro";
import ProfilesSection from "../components/profiles/ProfilesSection.vue";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Perfiles | GeneraRecetas"
  description="Perfiles de acceso de GeneraRecetas para propietarios, profesionales, comercializadoras, entidades y perfiles del sector veterinario y ganadero."
  canonical="/perfiles"
>
  <style is:inline>
    .profiles-stage {
      opacity: 0;
      transform: translate3d(0, 20px, 0);
      animation: profiles-stage-enter 680ms cubic-bezier(0.22, 1, 0.36, 1) 160ms forwards;
      will-change: opacity, transform;
    }

    @keyframes profiles-stage-enter {
      from {
        opacity: 0;
        transform: translate3d(0, 20px, 0);
      }

      to {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .profiles-stage {
        opacity: 1;
        transform: none;
        animation: none;
      }
    }
  </style>

  <SiteHeader />

  <main class="px-[14px] pb-0 pt-[24px] md:pt-[30px] min-[1200px]:px-[20px] min-[1200px]:pt-[38px]">
    <div class="profiles-stage">
      <ProfilesSection client:media="(max-width: 1199px)" />
    </div>
  </main>
</BaseLayout>
