---
import { Image } from "astro:assets";
import SiteHeader from "../components/header/SiteHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import gestiongrLogo from "../assets/logos/logo-gestiongr.svg";
---

<BaseLayout
  title="GestionGR | GeneraRecetas"
  description="Conoce GestionGR, la plataforma que conecta aplicaciones, servicios y perfiles del ecosistema digital de GeneraRecetas."
  canonical="/gestiongr"
>
  <SiteHeader />

  <main class="bg-white px-[14px] pb-[48px] pt-0 md:px-[20px] md:pb-[72px]">
    <section class="mx-auto w-full max-w-[1040px] py-[20px] md:py-[34px]">
      <div class="relative overflow-hidden rounded-[28px] border border-gr-border/32 bg-[linear-gradient(135deg,rgba(255,255,255,0.98),rgba(243,248,250,0.98))] px-[18px] py-[22px] shadow-[0_22px_52px_-34px_rgba(20,49,62,0.35)] md:px-[32px] md:py-[34px]">
        <div class="pointer-events-none absolute inset-x-0 top-0 h-[1px] bg-[linear-gradient(90deg,rgba(47,86,104,0),rgba(182,160,79,0.7),rgba(47,86,104,0))]"></div>
        <div class="pointer-events-none absolute right-[-48px] top-[-48px] h-[180px] w-[180px] rounded-full bg-gr-gold/10 blur-3xl"></div>

        <div class="relative max-w-[760px] reveal-up">
          <Image
            src={gestiongrLogo}
            alt="GestionGR"
            class="h-auto w-[168px] md:w-[196px]"
            loading="eager"
            width="316"
            height="72"
          />

          <h1 class="mt-[20px] font-space text-[2rem] font-[700] leading-[1.04] text-gr-blue md:mt-[24px] md:text-[3.35rem]">
            Todo tu ecosistema digital en un solo lugar
          </h1>

          <p class="mt-[16px] max-w-[700px] text-[1rem] leading-[1.75] text-gr-blue/82 md:text-[1.08rem]">
            GestionGR reune usuarios, productos, servicios y aplicaciones en una única entrada para que cada perfil acceda de
            forma simple a las herramientas que necesita.
          </p>

          <p class="mt-[10px] max-w-[700px] text-[0.98rem] leading-[1.72] text-gr-blue/68 md:text-[1.02rem]">
            GeneraRecetas forma parte de este ecosistema, manteniendo su espacio propio dentro de una plataforma conectada y
            ordenada.
          </p>
        </div>

        <div class="relative mt-[22px] grid gap-[10px] rounded-[22px] border border-gr-border/28 bg-[linear-gradient(135deg,rgba(47,86,104,0.035),rgba(255,255,255,0.82))] p-[14px] reveal-up reveal-delay-1 md:mt-[28px] md:grid-cols-3 md:gap-[12px] md:p-[18px]">
          <div class="rounded-[18px] border border-gr-border/18 bg-white/78 px-[14px] py-[14px]">
            <p class="font-space text-[1rem] font-[600] leading-[1.3] text-gr-blue">Acceso centralizado a aplicaciones del entorno</p>
          </div>
          <div class="rounded-[18px] border border-gr-border/18 bg-white/78 px-[14px] py-[14px]">
            <p class="font-space text-[1rem] font-[600] leading-[1.3] text-gr-blue">Experiencia clara y adaptada a cada perfil</p>
          </div>
          <div class="rounded-[18px] border border-gr-border/18 bg-white/78 px-[14px] py-[14px]">
            <p class="font-space text-[1rem] font-[600] leading-[1.3] text-gr-blue">Gestión mas simple para el día a día</p>
          </div>
        </div>

        <div class="relative mt-[22px] reveal-up reveal-delay-2 md:mt-[28px]">
          <button
            type="button"
            aria-disabled="true"
            class="inline-flex min-h-[54px] items-center justify-center rounded-full border border-gr-blue/12 bg-gr-blue px-[22px] py-[14px] font-space text-[0.98rem] font-[600] tracking-[0.01em] text-white shadow-[0_16px_32px_-24px_rgba(20,49,62,0.8)] transition-[background-color,transform,box-shadow] duration-200 hover:bg-[#5bbdbe] hover:shadow-[0_18px_34px_-24px_rgba(91,189,190,0.72)] active:scale-[0.99] md:min-h-[58px] md:px-[26px]"
          >
            Ir a la suite de GestionGR
          </button>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
