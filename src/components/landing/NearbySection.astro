---
import NearbyMap from "./NearbyMap.astro";
---

<section
  class="relative mt-0 w-full py-[30px] md:py-[40px] min-[1200px]:py-[54px]"
  style="content-visibility: auto; contain-intrinsic-size: 720px;"
  aria-labelledby="nearby-title"
>
  <span class="pointer-events-none absolute inset-y-0 left-1/2 -z-10 w-screen -translate-x-1/2 bg-[rgb(238_244_247_/_0.44)]" aria-hidden="true"></span>
  <span class="pointer-events-none absolute left-1/2 bottom-0 h-px w-screen -translate-x-1/2 bg-gr-border/16" aria-hidden="true"></span>

  <div class="mx-auto w-full max-w-[1200px] px-[16px] md:px-[24px] min-[1200px]:px-[32px]">
    <div class="grid items-center gap-[24px] min-[980px]:grid-cols-[minmax(0,1fr)_minmax(320px,420px)] min-[1200px]:gap-[32px]">
      <div class="max-w-[760px] reveal-up">
        <p
          id="nearby-title"
          class="font-space text-[1.22rem] font-[600] uppercase tracking-[0.18em] text-gr-gold md:text-[1.42rem] min-[1200px]:text-[1.56rem]"
        >
          Muy cerca de ti.
        </p>
        <p class="gr-body mt-[14px] text-[1.02rem] leading-[1.82] text-gr-blue md:mt-[18px] md:text-[1.14rem] md:leading-[1.88]">
          Nos encontramos trabajando en todas las provincias estatales para ayudarte, adaptándonos a las exigencias de cada comunidad y extendiéndonos a más países. Poniendo en marcha la legislación sobre sanidad animal resolutiva por la UE y donde ofrecemos la mejor y más cercana atención.
        </p>
      </div>

      <figure class="mx-auto w-full max-w-[310px] reveal-up reveal-delay-1 md:max-w-[350px] min-[1200px]:max-w-[370px]">
        <NearbyMap />
      </figure>
    </div>
  </div>
</section>
