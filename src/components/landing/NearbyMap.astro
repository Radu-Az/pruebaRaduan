---
import { readFileSync } from "node:fs";
import { join } from "node:path";

const rawMapSvg = readFileSync(join(process.cwd(), "public", "images", "maps", "mapa.svg"), "utf-8");

const interactiveMapSvg = rawMapSvg
  .replace(/<a\b([^>]*)title="([^"]+)"([^>]*)>/g, (_match, before, title, after) => {
    const escapedTitle = title.replace(/"/g, "&quot;");
    return `<g${before} data-region-label="${escapedTitle}"${after}>`;
  })
  .replace(/\s+title="[^"]*"/g, "")
  .replace(/<\/a>/g, "</g>");
---

<div class="nearby-map-shell relative w-full" data-nearby-map aria-label="Mapa de cobertura de GeneraRecetas en Espana, Portugal y Francia">
  <div class="nearby-map-graphic w-full" data-nearby-graphic set:html={interactiveMapSvg}></div>
  <div class="nearby-map-tooltip" data-nearby-tooltip aria-hidden="true"></div>
</div>

<style is:global>
  .nearby-map-shell {
    isolation: isolate;
  }

  .nearby-map-graphic > svg {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    overflow: visible;
  }

  .nearby-map-graphic > svg [data-region-label] {
    cursor: pointer;
    transform-box: fill-box;
    transform-origin: center;
    transition:
      scale 180ms ease,
      filter 180ms ease,
      opacity 180ms ease;
    will-change: scale;
  }

  .nearby-map-graphic > svg [data-region-label] path,
  .nearby-map-graphic > svg [data-region-label] g,
  .nearby-map-graphic > svg [data-region-label] circle {
    transition:
      fill 180ms ease,
      stroke 180ms ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .nearby-map-graphic > svg [data-region-label]:hover {
      scale: 1.018;
      filter: drop-shadow(0 8px 14px rgba(91, 189, 190, 0.14));
      opacity: 0.98;
    }

    .nearby-map-graphic > svg [data-region-label]:hover path,
    .nearby-map-graphic > svg [data-region-label]:hover g,
    .nearby-map-graphic > svg [data-region-label]:hover circle {
      fill: #d1c08e;
      stroke: #9f8530;
    }
  }

  .nearby-map-tooltip {
    pointer-events: none;
    position: absolute;
    left: 0;
    top: 0;
    z-index: 4;
    max-width: min(220px, calc(100% - 24px));
    border: 1px solid rgba(47, 86, 104, 0.16);
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(47, 86, 104, 0.96), rgba(36, 73, 91, 0.96));
    box-shadow: 0 18px 34px -22px rgba(20, 49, 62, 0.72);
    color: #fff;
    font-family: var(--font-space, "Space Grotesk", sans-serif);
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: 0.01em;
    padding: 10px 12px;
    opacity: 0;
    transform: translate3d(0, 8px, 0) scale(0.92);
    transform-origin: center;
    filter: blur(8px);
    transition:
      opacity 140ms ease,
      transform 180ms ease,
      filter 180ms ease;
    white-space: nowrap;
  }

  .nearby-map-tooltip-content {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .nearby-map-tooltip-flag {
    display: block;
    height: 16px;
    width: 22px;
    flex: 0 0 auto;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: 0 6px 12px -10px rgba(0, 0, 0, 0.55);
    object-fit: cover;
    background: rgba(255, 255, 255, 0.08);
  }

  .nearby-map-tooltip-label {
    display: inline-block;
  }

  .nearby-map-tooltip::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -6px;
    height: 12px;
    width: 12px;
    border-right: 1px solid rgba(47, 86, 104, 0.16);
    border-bottom: 1px solid rgba(47, 86, 104, 0.16);
    background: #24495b;
    transform: translateX(-50%) rotate(45deg);
  }

  .nearby-map-tooltip.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    filter: blur(0);
    animation: nearby-map-tooltip-in 200ms cubic-bezier(0.2, 0.82, 0.24, 1) both;
  }

  @keyframes nearby-map-tooltip-in {
    0% {
      opacity: 0;
      transform: translate3d(0, 10px, 0) scale(0.9);
      filter: blur(10px);
    }

    70% {
      opacity: 1;
      transform: translate3d(0, -1px, 0) scale(1.015);
      filter: blur(0);
    }

    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
      filter: blur(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nearby-map-graphic > svg [data-region-label],
    .nearby-map-graphic > svg [data-region-label] path,
    .nearby-map-graphic > svg [data-region-label] g,
    .nearby-map-graphic > svg [data-region-label] circle,
    .nearby-map-tooltip {
      transition: none;
    }

    .nearby-map-tooltip.is-visible {
      animation: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const flagByRegion = {
      portugal: "/images/maps/Flag_of_Portugal.svg",
      francia: "/images/maps/Flag_of_France.svg",
      andalucia: "/images/maps/Flag_of_Andaluc%C3%ADa.svg",
      aragon: "/images/maps/Bandera_de_Arag%C3%B3n.svg",
      asturias: "/images/maps/Flag_of_Asturias.svg",
      cantabria: "/images/maps/Flag_of_Cantabria_(Official).svg",
      "castila y leon": "/images/maps/Flag_of_Castile_and_Le%C3%B3n.svg",
      "castila-la mancha": "/images/maps/Flag_of_Castile-La_Mancha.svg",
      cataluna: "/images/maps/Flag_of_Catalonia.svg",
      ceuta: "/images/maps/Flag_of_Ceuta.svg",
      extremadura: "/images/maps/Flag_of_Extremadura,_Spain.svg",
      galicia: "/images/maps/Flag_of_Galicia.svg",
      "islas baleares": "/images/maps/Flag_of_the_Balearic_Islands.svg",
      "islas canarias": "/images/maps/Flag_of_the_Canary_Islands_(simple).svg",
      "la rioja": "/images/maps/Bandera_de_La_Rioja.svg",
      madrid: "/images/maps/Flag_of_the_Community_of_Madrid.svg",
      melilla: "/images/maps/Flag_of_Melilla.svg",
      murcia: "/images/maps/Flag_of_the_Region_of_Murcia.svg",
      navarra: "/images/maps/Bandera_de_Navarra.svg",
      "pais vasco": "/images/maps/Flag_of_the_Basque_Country.svg",
      valencia: "/images/maps/Flag_of_the_Valencian_Community_(2x3).svg"
    };

    const supportsHover = window.matchMedia("(hover: hover) and (pointer: fine)").matches;

    const normalizeLabel = (value) =>
      String(value || "")
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/\s+/g, " ")
        .trim()
        .toLowerCase();

    document.querySelectorAll("[data-nearby-map]").forEach((shell) => {
      const tooltip = shell.querySelector("[data-nearby-tooltip]");
      const graphic = shell.querySelector("[data-nearby-graphic]");
      const regions = graphic?.querySelectorAll("svg [data-region-label]") ?? [];

      if (!tooltip || !regions.length) {
        return;
      }

      let activeRegion = null;

      const showTooltip = (region, event) => {
        const label = region.getAttribute("data-region-label");
        if (!label) {
          return;
        }

        activeRegion = region;
        tooltip.replaceChildren();

        const content = document.createElement("span");
        content.className = "nearby-map-tooltip-content";

        const flag = flagByRegion[normalizeLabel(label)];
        if (flag) {
          const image = document.createElement("img");
          image.className = "nearby-map-tooltip-flag";
          image.src = flag;
          image.alt = "";
          image.width = 22;
          image.height = 16;
          image.decoding = "async";
          content.appendChild(image);
        }

        const text = document.createElement("span");
        text.className = "nearby-map-tooltip-label";
        text.textContent = label;
        content.appendChild(text);

        tooltip.appendChild(content);
        tooltip.classList.add("is-visible");
        tooltip.setAttribute("aria-hidden", "false");
        positionTooltip(event);
      };

      const hideTooltip = () => {
        activeRegion = null;
        tooltip.classList.remove("is-visible");
        tooltip.setAttribute("aria-hidden", "true");
      };

      const positionTooltip = (event) => {
        if (!activeRegion) {
          return;
        }

        const shellRect = shell.getBoundingClientRect();
        const tooltipRect = tooltip.getBoundingClientRect();
        const offsetX = 14;
        const offsetY = 18;
        const maxLeft = Math.max(8, shellRect.width - tooltipRect.width - 8);

        let left = event.clientX - shellRect.left - tooltipRect.width / 2;
        let top = event.clientY - shellRect.top - tooltipRect.height - offsetY;

        left = Math.min(Math.max(8, left), maxLeft);

        if (top < 8) {
          top = Math.min(shellRect.height - tooltipRect.height - 8, event.clientY - shellRect.top + offsetX);
        }

        tooltip.style.left = left + "px";
        tooltip.style.top = top + "px";
      };

      regions.forEach((region) => {
        if (supportsHover) {
          region.addEventListener("mouseenter", (event) => {
            showTooltip(region, event);
          });

          region.addEventListener("mousemove", (event) => {
            if (activeRegion === region) {
              positionTooltip(event);
            }
          });

          region.addEventListener("mouseleave", () => {
            if (activeRegion === region) {
              hideTooltip();
            }
          });

          return;
        }

        region.addEventListener("click", (event) => {
          event.stopPropagation();
          showTooltip(region, event);
        });
      });

      if (!supportsHover) {
        shell.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element) || !target.closest("[data-region-label]")) {
            hideTooltip();
          }
        });
      }
    });
  })();
</script>
