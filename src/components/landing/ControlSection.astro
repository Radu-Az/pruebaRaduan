---
import { Image } from "astro:assets";
import controlImage from "../../assets/landing/ControlTranquilidad.png";
---

<section
  class="relative mt-0 w-full py-[28px] md:py-[34px] min-[1200px]:py-[42px]"
  style="content-visibility: auto; contain-intrinsic-size: 760px;"
  aria-labelledby="control-section-title"
>
  <span class="pointer-events-none absolute inset-y-0 left-1/2 -z-10 w-screen -translate-x-1/2 bg-[rgb(47_86_104_/_0.035)]" aria-hidden="true"></span>
  <span class="pointer-events-none absolute left-1/2 top-0 h-px w-screen -translate-x-1/2 bg-gr-border/22" aria-hidden="true"></span>
  <span class="pointer-events-none absolute left-1/2 bottom-0 h-px w-screen -translate-x-1/2 bg-gr-border/18" aria-hidden="true"></span>

  <div class="mx-auto w-full max-w-[1200px] px-[16px] md:px-[24px] min-[1200px]:px-[32px]">
    <div class="grid items-center gap-[24px] min-[980px]:grid-cols-[minmax(320px,480px)_minmax(0,1fr)] min-[1200px]:gap-[40px]">
      <figure class="mx-auto w-full max-w-[360px] reveal-up md:max-w-[420px] min-[980px]:mx-0 min-[1200px]:max-w-[460px]">
        <Image
          src={controlImage}
          alt="Control y tranquilidad"
          class="block h-auto w-full"
          loading="lazy"
          format="webp"
          quality={68}
          widths={[320, 420, 560, 760]}
          sizes="(min-width: 1200px) 460px, (min-width: 980px) 420px, (min-width: 768px) 420px, calc(100vw - 32px)"
        />
      </figure>

      <div class="max-w-[700px] reveal-up reveal-delay-1">
        <p class="font-space text-[1.72rem] font-[700] leading-[1.06] text-gr-gold md:text-[2.5rem]">
          Control y tranquilidad
        </p>
        <h2
          id="control-section-title"
          class="mt-[10px] font-space text-[1rem] font-[600] leading-[1.4] text-gr-blue md:text-[1.2rem]"
        >
          Velamos por tu seguridad y privacidad
        </h2>
        <p class="mt-[16px] text-[1rem] leading-[1.76] text-gr-blue/84 md:text-[1.08rem] md:leading-[1.84]">
          Tenemos la mejor protección para tí, durante 5 años para consultar tus recetas. Realizamos copias de
          seguridad constantes en servidores profesionales para que todo tu trabajo esté protegido.
        </p>
      </div>
    </div>
  </div>
</section>
