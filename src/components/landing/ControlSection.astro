---
import { Image } from "astro:assets";
import controlImage from "../../assets/landing/ControlTranquilidad.webp";
---

<section
  class="landing-control relative mt-0 w-full py-[34px] md:py-[44px] min-[1200px]:py-[56px]"
  style="content-visibility: auto; contain-intrinsic-size: 860px;"
  aria-labelledby="control-section-title"
>
  <span class="pointer-events-none absolute inset-y-0 left-1/2 -z-10 w-screen -translate-x-1/2 bg-white" aria-hidden="true"></span>
  <span class="pointer-events-none absolute left-1/2 top-0 h-px w-screen -translate-x-1/2 bg-gr-border/24" aria-hidden="true"></span>
  <span class="pointer-events-none absolute left-1/2 bottom-0 h-px w-screen -translate-x-1/2 bg-gr-border/16" aria-hidden="true"></span>

  <div class="mx-auto w-full max-w-[1240px] px-[26px] md:px-[42px] min-[1200px]:px-[64px]">
    <div class="grid items-center gap-[26px] min-[980px]:min-h-[640px] min-[980px]:grid-cols-[minmax(0,1.04fr)_minmax(0,0.96fr)] min-[1200px]:gap-[46px]">
      <figure class="order-2 reveal-up min-[980px]:order-1">
        <div class="relative mx-auto w-full max-w-[500px] overflow-hidden rounded-[34px] border border-gr-border/28 bg-white/68 shadow-[0_20px_44px_-30px_rgba(20,49,62,0.4)] md:rounded-[42px] min-[980px]:mx-0">
          <Image
            src={controlImage}
            alt="Control y tranquilidad"
            class="block aspect-square h-auto w-full object-cover"
            loading="lazy"
            format="webp"
            quality={68}
            widths={[420, 640, 840, 1120]}
            sizes="(min-width: 1200px) 50vw, (min-width: 980px) 48vw, 100vw"
          />
          <span class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,rgba(47,86,104,0)_45%,rgba(47,86,104,0.18)_100%)]" aria-hidden="true"></span>
        </div>
      </figure>

      <div class="order-1 mx-auto w-full max-w-[640px] reveal-up reveal-delay-1 min-[980px]:order-2 min-[980px]:mx-0">
        <p class="font-space text-[0.8rem] font-[700] uppercase tracking-[0.16em] text-gr-gold/92">
          PROTECCI&Oacute;N Y RESPALDO
        </p>
        <h2
          id="control-section-title"
          class="mt-[10px] font-space text-[2.02rem] font-[700] leading-[1.06] text-gr-blue md:text-[3rem]"
        >
          Control y tranquilidad
        </h2>
        <p class="mt-[10px] font-space text-[1.03rem] font-[600] leading-[1.4] text-gr-gold md:text-[1.28rem]">
          Velamos por tu seguridad y privacidad
        </p>
        <p class="mt-[16px] text-[1rem] leading-[1.76] text-gr-blue/84 md:text-[1.08rem] md:leading-[1.84]">
          Tenemos la mejor protecci&oacute;n para ti, durante 5 a&ntilde;os para consultar tus recetas. Realizamos copias de
          seguridad constantes en servidores profesionales para que todo tu trabajo est&eacute; protegido.
        </p>
      </div>
    </div>
  </div>
</section>
