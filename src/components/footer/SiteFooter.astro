---
import { Image } from "astro:assets";
import { navItems, resourcesItems } from "../../data/site-navigation";
import footerLogo from "../../assets/logos/GRlogoFooter.svg";
import ntecLogo from "../../assets/logos/logo-ntec.svg";

const currentYear = new Date().getFullYear();
const primaryLinks = navItems.filter((item) => item.href && item.href !== "#");
const secondaryLinks = resourcesItems.filter((item) => item.href && item.href !== "#");
const supportLinks = [
  { label: "Windows software", href: "https://www.teamviewer.com/es/download/windows/" },
  { label: "macOS software", href: "https://www.teamviewer.com/es/download/macos/" }
];
---

<footer class="bg-[#284c5d] py-[40px] text-white md:py-[56px]" style="content-visibility: auto; contain-intrinsic-size: 720px;">
  <div class="mx-auto w-full max-w-[1280px] px-[14px] md:px-[20px]">
    <div class="grid grid-cols-1 gap-[34px] sm:grid-cols-2 md:grid-cols-4 md:gap-[42px]">
      <section class="sm:col-span-2 md:col-span-1">
        <Image
          src={footerLogo}
          alt="GeneraRecetas"
          class="h-auto w-[152px] md:w-[176px]"
          loading="lazy"
        />
        <p class="mt-[16px] max-w-[260px] text-[0.96rem] leading-[1.68] text-white/72">
          GeneraRecetas impulsa la receta electr&oacute;nica veterinaria y la gesti&oacute;n profesional del sector
          veterinario y ganadero.
        </p>
      </section>

      <section>
        <h4 class="mb-[14px] font-space text-[0.82rem] font-[700] uppercase tracking-[0.18em] text-white">
          Navegaci&oacute;n
        </h4>
        <ul class="space-y-[10px] text-[0.98rem] text-white/74">
          {primaryLinks.map((item) => (
            <li>
              <a
                href={item.href}
                class="transition-colors duration-200 hover:text-white focus-visible:text-white"
                data-astro-prefetch
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section>
        <h4 class="mb-[14px] font-space text-[0.82rem] font-[700] uppercase tracking-[0.18em] text-white">
          Recursos
        </h4>
        <ul class="space-y-[10px] text-[0.98rem] text-white/74">
          {secondaryLinks.map((item) => (
            <li>
              <a
                href={item.href}
                class="transition-colors duration-200 hover:text-white focus-visible:text-white"
                data-astro-prefetch
              >
                {item.title}
              </a>
            </li>
          ))}
          {supportLinks.map((item) => (
            <li>
              <a
                href={item.href}
                class="transition-colors duration-200 hover:text-white focus-visible:text-white"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section>
        <h4 class="mb-[14px] font-space text-[0.82rem] font-[700] uppercase tracking-[0.18em] text-white">
          Contacto
        </h4>
        <ul class="space-y-[11px] text-[0.98rem] text-white/74">
          <li class="flex items-start gap-[10px]">
            <svg class="mt-[2px] h-[16px] w-[16px] shrink-0 text-white/46" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@generarecetas.com" class="transition-colors duration-200 hover:text-white focus-visible:text-white">
              info@generarecetas.com
            </a>
          </li>
          <li class="flex items-start gap-[10px]">
            <svg class="mt-[2px] h-[16px] w-[16px] shrink-0 text-white/46" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+34948482356" class="transition-colors duration-200 hover:text-white focus-visible:text-white">
              948 48 23 56
            </a>
          </li>
          <li class="flex items-start gap-[10px]">
            <svg class="mt-[2px] h-[16px] w-[16px] shrink-0 text-white/46" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Pol. Mutilva E-11, Piso 2. Oficina 2B, 31192 (Navarra)</span>
          </li>
          <li class="pt-[4px]">
            <a
              href="/contacto"
              class="inline-flex items-center gap-[8px] rounded-full border border-white/18 bg-white/10 px-[16px] py-[9px] text-[0.92rem] font-[600] text-white transition-[background-color,border-color] duration-200 hover:border-white/28 hover:bg-white/18"
              data-astro-prefetch
            >
              <svg class="h-[15px] w-[15px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              Contacto
            </a>
          </li>
        </ul>
      </section>
    </div>

    <div class="mt-[34px] flex flex-col items-center justify-between gap-[14px] border-t border-white/14 pt-[20px] text-[0.82rem] text-white/72 sm:flex-row sm:text-[0.9rem]">
      <span class="inline-flex items-center gap-[6px] text-center sm:text-left">
        <span>&copy; {currentYear} powered by</span>
        <Image
          src={ntecLogo}
          alt="Ntec"
          class="inline-block h-auto w-[58px] shrink-0"
          loading="lazy"
        />
      </span>

      <nav class="flex flex-wrap justify-center gap-[16px] sm:gap-[22px]" aria-label="Legal">
        <a href="/politica-privacidad" class="transition-colors duration-200 hover:text-white" data-astro-prefetch>
          Pol&iacute;tica de privacidad
        </a>
        <a href="/aviso-legal" class="transition-colors duration-200 hover:text-white" data-astro-prefetch>
          Aviso legal
        </a>
      </nav>
    </div>
  </div>
</footer>
