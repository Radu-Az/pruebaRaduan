---
const currentYear = new Date().getFullYear();
---

<footer class="mt-0 bg-gradient-to-b from-[#2f5668] to-[#284c5d] text-white">
  <div class="relative mx-auto w-full max-w-[1280px] px-[14px] pb-[58px] pt-[46px] md:px-[20px] md:pb-[68px] md:pt-[58px]">
    <a
      href="#page-top"
      aria-label="Volver arriba"
      class="absolute -bottom-[24px] left-[12px] inline-flex h-[48px] w-[48px] items-center justify-center rounded-full border border-white/16 bg-[#356984] text-white shadow-[0_10px_20px_rgba(0,0,0,0.24)] transition-[background-color,transform,box-shadow] duration-200 hover:bg-[#3f7692] hover:shadow-[0_12px_24px_rgba(0,0,0,0.28)] active:scale-[0.97] md:h-[54px] md:w-[54px] md:-bottom-[28px]"
    >
      <svg viewBox="0 0 24 24" class="h-[22px] w-[22px] fill-none stroke-current stroke-[2.2]" aria-hidden="true">
        <path d="M12 19V5M6 11l6-6 6 6" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </a>

    <div class="flex flex-col gap-[34px] lg:flex-row lg:items-start lg:gap-[88px]">
      <div class="flex items-start gap-[14px] md:gap-[16px] lg:w-[320px] lg:shrink-0 lg:pt-[2px]">
        <img
          src="/images/logos/logo-generarecetas-icon.svg"
          alt=""
          class="mt-[3px] h-auto w-[28px] shrink-0 md:w-[34px]"
          width="58"
          height="81"
          loading="lazy"
          decoding="async"
        />
        <div class="font-space leading-[0.96]">
          <p class="text-[2.1rem] font-[500] text-gr-gold md:text-[2.3rem]">genera</p>
          <p class="text-[2.1rem] font-[600] text-gr-gold md:text-[2.3rem]">recetas</p>
          <p class="text-[2.1rem] font-[500] text-white md:text-[2.3rem]">.com</p>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-[14px] sm:grid-cols-2 sm:gap-[14px] lg:ml-auto lg:w-full lg:max-w-[860px] lg:grid-cols-3">
        <section class="py-[4px]">
          <h3 class="font-space text-[1.34rem] font-[600] leading-[1.15] text-white">Contacto</h3>
          <div class="mt-[10px] h-px w-[132px] bg-gr-gold"></div>
          <div class="mt-[13px] flex flex-col items-start gap-[8px] text-[1rem] text-white/92 md:text-[1.05rem]">
            <a href="mailto:info@generarecetas.com" class="inline-block transition-colors duration-200 hover:text-gr-gold">
              info@generarecetas.com
            </a>
            <a href="tel:+34948482356" class="inline-block transition-colors duration-200 hover:text-gr-gold">948 482 356</a>
          </div>
        </section>

        <section class="py-[4px]">
          <h3 class="font-space text-[1.34rem] font-[600] leading-[1.15] text-white">Informaci&oacute;n</h3>
          <div class="mt-[10px] h-px w-[132px] bg-gr-gold"></div>
          <div class="mt-[13px] flex flex-col items-start gap-[8px] text-[1rem] text-white/92 md:text-[1.05rem]">
            <a href="/politica-privacidad" class="inline-block transition-colors duration-200 hover:text-gr-gold">Pol&iacute;tica de privacidad</a>
            <a href="/aviso-legal" class="inline-block transition-colors duration-200 hover:text-gr-gold">Aviso legal</a>
          </div>
        </section>

        <section class="py-[4px] sm:col-span-2 lg:col-span-1">
          <h3 class="font-space text-[1.34rem] font-[600] leading-[1.15] text-white">Atenci&oacute;n</h3>
          <div class="mt-[10px] h-px w-[132px] bg-gr-gold"></div>
          <div class="mt-[13px] flex flex-col items-start gap-[10px] text-[1rem] text-white/92 md:text-[1.05rem]">
            <div class="flex items-center gap-[10px]">
              <span class="inline-flex h-[22px] w-[22px] items-center justify-center rounded-[6px] border border-white/55 text-white/88">
                <svg viewBox="0 0 24 24" class="h-[12px] w-[12px] fill-none stroke-current stroke-[1.8]" aria-hidden="true">
                  <path d="M5 5h14v14H5zM12 5v14M5 12h14" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </span>
              <a href="https://www.teamviewer.com/es/download/windows/" class="inline-block transition-colors duration-200 hover:text-gr-gold">Windows software</a>
            </div>
            <div class="flex items-center gap-[10px]">
              <span class="inline-flex h-[22px] w-[22px] items-center justify-center rounded-[6px] border border-white/55 text-white/88">
                <svg viewBox="0 0 24 24" class="h-[12px] w-[12px] fill-none stroke-current stroke-[1.8]" aria-hidden="true">
                  <path d="M5 5h14v14H5zM12 5v14M5 12h14" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </span>
              <a href="https://www.teamviewer.com/es/download/macos/" class="inline-block transition-colors duration-200 hover:text-gr-gold">macOS software</a>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10 bg-[#24495b]">
    <div class="mx-auto flex min-h-[58px] w-full max-w-[1280px] items-center justify-center gap-[8px] px-[14px] py-[12px] text-center text-[0.95rem] text-white/92 md:px-[20px] md:text-[1.01rem]">
      <span>&copy; {currentYear} Powered by</span>
      <span class="inline-flex h-[20px] w-[20px] items-center justify-center rounded-[4px] border border-gr-gold/70 text-gr-gold">
        <svg viewBox="0 0 24 24" class="h-[12px] w-[12px] fill-none stroke-current stroke-[1.8]" aria-hidden="true">
          <path d="M5 5h14v14H5zM12 5v14M5 12h14" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </span>
      <span class="font-space text-[1.12rem] font-[500]">Ntec</span>
    </div>
  </div>
</footer>
