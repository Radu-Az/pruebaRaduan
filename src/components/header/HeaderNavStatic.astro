<style is:inline>
  .language-switcher > summary::-webkit-details-marker {
    display: none;
  }

  .language-switcher[open] > summary {
    border-color: rgb(0 0 0 / 0.55);
    box-shadow: 0 10px 18px rgb(47 86 104 / 8%);
  }

  .language-option.is-active {
    background: rgb(0 0 0 / 0.05);
  }

  .language-option.is-active span {
    color: rgb(0 0 0);
  }

  .mobile-menu-toggle:checked ~ .mobile-menu-shell .mobile-menu-panel {
    transform: translateX(0);
  }

  .mobile-nav-details > summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav-details[open] > summary .mobile-menu-chevron {
    transform: rotate(180deg);
  }

  .mobile-menu-panel {
    transform: translateX(100%);
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  html:has(#mobile-menu-toggle:checked),
  body:has(#mobile-menu-toggle:checked) {
    overflow: hidden;
  }
</style>

<script is:inline define:vars={{ defaultLanguage }}>
  (() => {
    const switchers = Array.from(document.querySelectorAll("[data-language-switcher]"));
    const currentLabels = Array.from(document.querySelectorAll("[data-language-current]"));
    const optionButtons = Array.from(document.querySelectorAll("[data-language-option]"));

    if (!switchers.length || !currentLabels.length || !optionButtons.length) {
      return;
    }

    const storageKey = "gr-language";
    const labels = new Map();
    const allowed = new Set();

    optionButtons.forEach((button) => {
      const value = button.getAttribute("data-language-option");
      const shortLabel = button.querySelector("span")?.textContent?.trim();

      if (!value || !shortLabel) {
        return;
      }

      allowed.add(value);
      labels.set(value, shortLabel);
    });

    const getStoredLanguage = () => {
      try {
        const stored = window.localStorage.getItem(storageKey);
        return stored && allowed.has(stored) ? stored : null;
      } catch {
        return null;
      }
    };

    const applyLanguage = (value) => {
      const nextValue = allowed.has(value) ? value : defaultLanguage;

      currentLabels.forEach((label) => {
        label.textContent = labels.get(nextValue) || nextValue.toUpperCase();
      });

      optionButtons.forEach((button) => {
        const isActive = button.getAttribute("data-language-option") === nextValue;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
      });

      document.documentElement.lang = nextValue;

      try {
        window.localStorage.setItem(storageKey, nextValue);
      } catch {
        // Ignore storage failures.
      }
    };

    applyLanguage(getStoredLanguage() || defaultLanguage);

    optionButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const nextValue = button.getAttribute("data-language-option");

        if (!nextValue) {
          return;
        }

        applyLanguage(nextValue);
        switchers.forEach((switcher) => {
          switcher.removeAttribute("open");
        });
      });
    });

    switchers.forEach((switcher) => {
      switcher.addEventListener("toggle", () => {
        if (!switcher.hasAttribute("open")) {
          return;
        }

        switchers.forEach((otherSwitcher) => {
          if (otherSwitcher === switcher) {
            return;
          }

          otherSwitcher.removeAttribute("open");
        });
      });
    });

    document.addEventListener("click", (event) => {
      const target = event.target;

      if (!(target instanceof Node)) {
        return;
      }

      if (switchers.some((switcher) => switcher.contains(target))) {
        return;
      }

      switchers.forEach((switcher) => {
        switcher.removeAttribute("open");
      });
    });
  })();
</script>
