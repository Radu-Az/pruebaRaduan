---
import { Image } from "astro:assets";
import HeaderNav from "./HeaderNavStatic.astro";
import headerLogo from "../../assets/logos/GRlogoOscuro.svg";
---

<header
  data-landing-header
  data-scrolled="false"
  class="landing-header sticky top-0 relative z-[300] isolate mx-auto flex w-full items-center justify-between gap-[10px] bg-[#efe9d3] px-[14px] pt-[10px] pb-[10px] shadow-none md:px-[20px] md:pb-[11px] min-[1200px]:gap-[16px] min-[1200px]:pl-[26px] min-[1200px]:pr-[0px] min-[1200px]:pt-[14px] min-[1200px]:pb-[14px]"
>
  <span class="landing-header-divider pointer-events-none absolute inset-x-0 bottom-0 z-[250] h-[2px]" aria-hidden="true"></span>

  <a class="landing-brand shrink-0" href="/" aria-label="Ir al inicio" data-astro-prefetch>
    <Image
      src={headerLogo}
      alt="GeneraRecetas"
      class="block h-auto w-[184px] md:w-[200px] min-[1200px]:w-[230px]"
      width="388"
      height="81"
    />
  </a>

  <HeaderNav />
</header>

<style is:inline>
  [data-landing-header] .landing-header-divider {
    background: transparent;
    opacity: 0;
    transition:
      background-color 440ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 440ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  [data-landing-header] .landing-header-divider::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    height: 22px;
    background: linear-gradient(
      to bottom,
      rgb(47 86 104 / 0.18) 0%,
      rgb(47 86 104 / 0.12) 18%,
      rgb(47 86 104 / 0.07) 42%,
      rgb(47 86 104 / 0.03) 68%,
      rgb(47 86 104 / 0) 100%
    );
    opacity: 0;
    transform: translateY(-4px);
    transition:
      opacity 460ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 460ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  [data-landing-header][data-scrolled="true"] .landing-header-divider {
    background: rgb(47 86 104 / 24%);
    opacity: 1;
  }

  [data-landing-header][data-scrolled="true"] .landing-header-divider::after {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  (() => {
    const header = document.querySelector("[data-landing-header]");

    if (!header) {
      return;
    }

    const syncHeader = () => {
      header.setAttribute("data-scrolled", window.scrollY > 4 ? "true" : "false");
    };

    syncHeader();
    window.addEventListener("scroll", syncHeader, { passive: true });
  })();
</script>
